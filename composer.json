{
    "name": "oxid-support/heartbeat",
    "description": "OXID eShop Heartbeat module with detailed request logging, correlation ID tracking, symbol monitoring, and GraphQL remote configuration",
    "type": "oxideshop-module",
    "license": [
        "proprietary"
    ],
    "authors": [
        {
            "name": "OXID Support",
            "email": "support@oxid-esales.com"
        }
    ],
    "require": {
        "oxid-esales/oxideshop-ce": "~7.0.0",
        "oxid-esales/graphql-base": "^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5 || ^11.0",
        "phpstan/phpstan": "^2.0",
        "squizlabs/php_codesniffer": "^4.0",
        "phpmd/phpmd": "^2.15"
    },
    "autoload": {
        "psr-4": {
            "OxidSupport\\Heartbeat\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "OxidSupport\\Heartbeat\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "phpcs": "phpcs --standard=tests/phpcs.xml --report=full",
        "phpcs-report": "phpcs --standard=tests/phpcs.xml --report=json --report-file=tests/Reports/phpcs.report.json",
        "phpcbf": "phpcbf --standard=tests/phpcs.xml",

        "phpstan": "phpstan -ctests/PhpStan/phpstan.neon analyse src/",
        "phpstan-report": "phpstan -ctests/PhpStan/phpstan.neon analyse src/ --error-format=json > tests/Reports/phpstan.report.json",

        "phpmd": "phpmd src ansi tests/PhpMd/standard.xml",
        "phpmd-report": "phpmd src json tests/PhpMd/standard.xml --reportfile tests/Reports/phpmd.report.json",

        "static": [
            "@phpcs",
            "@phpstan",
            "@phpmd"
        ],

        "tests-unit": "phpunit -c tests/phpunit.xml --testsuite='Unit Tests'",
        "tests-coverage": "XDEBUG_MODE=coverage phpunit -c tests/phpunit.xml --coverage-text --coverage-html=tests/Reports/CoverageHtml"
    },
    "config": {
        "allow-plugins": {
            "oxid-esales/oxideshop-unified-namespace-generator": true,
            "oxid-esales/oxideshop-composer-plugin": true
        },
        "audit": {
            "ignore": [
                "PKSA-hjpv-ct4c-8fq5",
                "PKSA-xwpn-zs9j-6wy5",
                "PKSA-sf9j-1gs7-xzvx",
                "PKSA-7h5p-prw9-w5nr",
                "PKSA-2q9d-8kh9-49wx",
                "PKSA-pght-23ww-rrdy",
                "PKSA-6y8p-nrf4-ysf5",
                "PKSA-yr6f-z9sx-cps3",
                "PKSA-28zg-9h7g-fhvp",
                "PKSA-54c6-f9b9-7wg4",
                "PKSA-wy1k-8qg5-z8xd",
                "PKSA-31hv-m6rg-8ryk",
                "PKSA-98zc-53yc-qt81",
                "PKSA-t4kv-1sv2-1mzx",
                "PKSA-wc9h-gs49-76tm",
                "PKSA-thph-wfk6-pp4j",
                "PKSA-hgp5-21g7-7phg"
            ]
        }
    }
}
